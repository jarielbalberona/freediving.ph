# Required for local dev
APP_ENV=development
LOG_LEVEL=debug
PORT=4000
DB_DSN=postgres://postgres:postgres@localhost:5432/fph?sslmode=disable
CORS_ORIGINS=http://localhost:3000

# Auth (Clerk)
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
DEV_AUTH=false

# Optional
API_BASE_URL=http://localhost:4000
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_CONN_MAX_LIFETIME=30m
RATE_LIMIT_PER_MINUTE=300
GOOGLE_MAPS_API_KEY=

# R2 / CDN (optional for media)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION=auto
CDN_BASE_URL=
MEDIA_SIGNING_SECRET_V1=
MEDIA_SIGNING_KEY_VERSION=1

# Feature secrets (optional)
CHIKA_PSEUDONYM_SECRET=
WS_FANOUT_CHANNEL=
