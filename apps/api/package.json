{
  "name": "@freediving.ph/api",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && biome lint .",
    "dev": "nodemon",
    "start": "tsx src/server.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "type-check": "tsc --noEmit",
    "test": "node --test test/**/*.test.mjs",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check-migrations": "node scripts/check-migrations.mjs",
    "db:explain-hot-queries": "node scripts/explain-hot-queries.mjs",
    "release:explore-hardening": "bash scripts/release-explore-hardening.sh",
    "audit:explore-backfill": "node scripts/audit-dive-spot-link-backfill.mjs",
    "check:explore-metrics": "node scripts/check-explore-metrics.mjs",
    "verify:explore-performance": "node scripts/verify-explore-api-performance.mjs",
    "verify:explore-flow": "bash scripts/verify-explore-flow.sh",
    "db:push": "drizzle-kit push",
    "db:clear": "tsx src/databases/drizzle/clean.ts",
    "db:seed": "tsx src/seed/superSeeder.ts",
    "destroy": "rimraf -g \"{node_modules,.next,.cache}\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@clerk/backend": "^2.17.1",
    "@clerk/express": "^1.7.70",
    "@faker-js/faker": "^9.5.0",
    "@freediving.ph/config": "workspace:*",
    "@freediving.ph/db": "workspace:*",
    "@freediving.ph/types": "workspace:*",
    "@freediving.ph/utils": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "ejs": "^3.1.10",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ip": "^2.0.1",
    "json-2-csv": "^5.5.8",
    "multer": "^2.0.2",
    "nodemailer": "^6.10.0",
    "nodemon": "^3.1.9",
    "pg": "^8.13.3",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.5",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "svix": "^1.15.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/ip": "^1.1.3",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/*.{css,scss}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/*.{json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af"
}
