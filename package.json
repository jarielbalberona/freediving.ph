{
  "name": "@freediving.ph/monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' dev",
    "build": "pnpm -r --if-present --filter './packages/*' build && pnpm build:api",
    "build:all": "pnpm build && pnpm build:web",
    "typecheck": "pnpm -r --if-present type-check",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "preflight": "pnpm typecheck && pnpm lint && pnpm test && pnpm build:api",
    "dev:web": "pnpm --filter @freediving.ph/web dev",
    "dev:api": "pnpm --filter @freediving.ph/api dev",
    "build:web": "pnpm --filter @freediving.ph/web build",
    "build:api": "pnpm --filter @freediving.ph/api build",
    "db:generate": "pnpm --filter @freediving.ph/db db:generate",
    "db:migrate": "pnpm --filter @freediving.ph/db db:migrate",
    "db:push": "pnpm --filter @freediving.ph/db db:push",
    "db:studio": "pnpm --filter @freediving.ph/db db:studio",
    "db:seed": "pnpm --filter @freediving.ph/api db:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "bcryptjs",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
