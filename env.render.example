# Render env template aligned with root render.yaml (Go API + Next.js web).

# Database URL is wired from render.yaml via fromDatabase:
# DB_DSN -> freediving-ph-db.connectionString

# API (services/fphgo) - required
APP_ENV=production
NODE_ENV=production
PORT=10000
CLERK_SECRET_KEY=sk_live_xxx
CHIKA_PSEUDONYM_SECRET=replace_with_long_random_secret
CORS_ORIGINS=https://freediving-ph-app.onrender.com
CORS_ORIGIN=https://freediving-ph-app.onrender.com
API_BASE_URL=https://freediving-ph-api.onrender.com

# API (services/fphgo) - optional
CLERK_JWT_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
GOOGLE_MAPS_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION=auto
CDN_BASE_URL=https://cdn.freediving.ph
MEDIA_SIGNING_KEY_VERSION=1
MEDIA_SIGNING_SECRET_V1=

# Web (apps/web) - required
NEXT_PUBLIC_FPHGO_BASE_URL=https://freediving-ph-api.onrender.com
FPHGO_BASE_URL=https://freediving-ph-api.onrender.com
NEXT_PUBLIC_API_URL=https://freediving-ph-api.onrender.com
NEXT_PUBLIC_APP_URL=https://freediving.ph
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# Web (apps/web) - optional
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Web SEO/analytics/monitoring
# Canonical public web origin is https://freediving.ph.
# Use GTM for future analytics flexibility, or GA4 directly if GTM is not used.
# If both are present, the web app loads GTM and ignores the direct GA4 path.
NEXT_PUBLIC_GTM_ID=GTM-xxxxxxx
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-search-console-token

# Sentry SaaS or GlitchTip via a Sentry-compatible DSN. Do not configure both.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Source map upload; required only if uploads are enabled for the deployment.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
